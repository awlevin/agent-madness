{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/api/install",
      "headers": [{ "key": "Content-Type", "value": "text/plain" }]
    },
    {
      "source": "/cli/(.*)",
      "headers": [{ "key": "Content-Type", "value": "text/plain" }]
    }
  ]
}
